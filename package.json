{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "serve:pm2": "vite preview --host 0.0.0.0 --strictPort --port ${ADMIN_PORT:-5173}",
    "start:pm2": "npm run build && npm run serve:pm2",
    "pm2:up": "bash scripts/server/pm2-up-admin.sh",
    "pm2:up:stack": "bash scripts/server/pm2-up-stack.sh",
    "db:apply": "psql \"$DATABASE_URL\" -f db/schema.sql",
    "db:import:activities": "node scripts/import-activities.mjs",
    "db:import:approved-images": "node scripts/import-approved-images.mjs",
    "db:local:up": "docker compose up -d postgres",
    "db:local:down": "docker compose down",
    "db:local:reset": "docker compose down -v",
    "db:local:logs": "docker compose logs -f postgres",
    "db:local:apply": "cat db/schema.sql | docker compose exec -T postgres psql -U fun_admin -d fun_admin",
    "db:local:import:houston": "DATABASE_URL=postgres://fun_admin:fun_admin@localhost:54329/fun_admin node scripts/import-activities.mjs --file \"Funzinga Activity Database - 2026-0224.csv\" --city-code HOU",
    "db:local:import:houston:dry-run": "DATABASE_URL=postgres://fun_admin:fun_admin@localhost:54329/fun_admin node scripts/import-activities.mjs --file \"Funzinga Activity Database - 2026-0224.csv\" --city-code HOU --dry-run",
    "db:local:import:approved-images": "DATABASE_URL=postgres://fun_admin:fun_admin@localhost:54329/fun_admin node scripts/import-approved-images.mjs --file \"approved-images-2026-02-25.jsonl\" --funcrawl-base-url \"https://funcrawl.buildwithspark.com\"",
    "db:local:import:approved-images:dry-run": "DATABASE_URL=postgres://fun_admin:fun_admin@localhost:54329/fun_admin node scripts/import-approved-images.mjs --file \"approved-images-2026-02-25.jsonl\" --funcrawl-base-url \"https://funcrawl.buildwithspark.com\" --dry-run",
    "db:local:bootstrap:houston": "npm run db:local:up && npm run db:local:apply && npm run db:local:import:houston"
  },
  "dependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "autoprefixer": "^10.4.24",
    "csv-parse": "^5.6.0",
    "pg": "^8.16.3",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
